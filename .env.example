# ── .env.example ── copy เป็น .env แล้วใส่ค่าจริง ──
# (ใน Render ใส่ใน Environment Variables แทน)

# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# Anthropic AI (วิเคราะห์สลิป)
ANTHROPIC_API_KEY=sk-ant-...

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/maruay?retryWrites=true&w=majority

# Admin
ADMIN_PASSWORD=Maruay01

# Server URL (สำหรับส่ง GIF ลูกเต๋าไป LINE)
# ใส่ URL ของ Render เช่น https://maruay-bot.onrender.com
SERVER_BASE_URL=https://your-app-name.onrender.com

# Port (Render กำหนดให้อัตโนมัติ ไม่ต้องตั้ง)
PORT=10000
